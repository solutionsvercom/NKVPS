# API base (include /api path). Leave unset in dev to use Vite proxy at /api.
# VITE_API_URL=http://localhost:5000/api

# Offline UI / no backend: use in-memory placeholder APIs (no Base44, no network).
# If true, the contact form returns success without calling your API — no emails are sent. Use false for production builds.
# VITE_USE_PLACEHOLDER_API=true
