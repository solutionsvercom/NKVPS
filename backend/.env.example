PORT=5000
# MongoDB: pick ONE approach.
#
# A) Atlas — Security → Network Access: add your IP, or 0.0.0.0/0 for local dev only (not production).
#    Include database name and query params, e.g.:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/littlestars?retryWrites=true&w=majority&appName=YourApp
#
# B) Local Mongo (Docker: `docker compose up -d` from repo root, or install MongoDB locally):
# USE_LOCAL_MONGO=1
# Optional override (default matches docker-compose.yml):
# MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/littlestars
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Comma-separated browser origins allowed by CORS. In production (NODE_ENV=production), only these are used.
# For local Vite (5173) / preview (4173), the server also allows localhost automatically when NODE_ENV is not production.
CLIENT_URL=http://localhost:5173

# --- SMTP (optional) — admission inquiry & contact form notifications ---
# If unset, forms still save to MongoDB; emails are skipped and a warning is logged once.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# MAIL_FROM=Navjyoti Kids Villa School <you@example.com>
# Optional: name used in auto-reply email bodies (defaults to Navjyoti Kids Villa School):
# MAIL_SCHOOL_NAME=Navjyoti Kids Villa School
# Optional tagline under the school name in HTML notification emails:
# MAIL_SCHOOL_TAGLINE=a Mother's Lap
# Inbox that receives the styled “card” copy of admission + contact submissions (defaults to SMTP_USER, e.g. school Gmail):
# MAIL_OWNER_INBOX=navjyotikidsvillaschool@gmail.com
# Absolute URL of your logo for HTML emails (many clients block relative URLs). Defaults to your live site /logo.png:
# MAIL_LOGO_URL=https://www.navjyotikidsvillaschool.in/logo.png
# Set to false to disable automatic thank-you emails to visitors:
# MAIL_SEND_AUTO_REPLY=false
# Log each successful SMTP send (recipient + subject) — useful when debugging delivery:
# MAIL_DEBUG=true
#
# Production: set SMTP_* and optional MAIL_OWNER_INBOX / MAIL_LOGO_URL on the host.

# Optional: allow creating admin accounts via /api/auth/register (same key must be entered on the signup form).
# Leave unset to disable admin self-signup — use `npm run seed` for the first admin instead.
# ADMIN_REGISTRATION_KEY=your-secret-key-here

# Optional: enables OpenAI instead of built-in fallback replies
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
